def classify_budget(budget: int):
    if budget < 500:
        return "low"
    elif 500 <= budget <= 2000: 
        return "mid"
    else:
        return "high"

def create_trip_summary(travel_request: TravelRequest):
    return f"The perfect travel plan for {travel_request.individuals} people from {travel_request.departure_city} for {travel_request.trip_length_days}"

